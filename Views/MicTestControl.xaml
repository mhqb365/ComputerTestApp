<UserControl x:Class="ComputerTestApp.Views.MicTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource MicTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource MicDescription}" Margin="0,0,0,20"/>
            <ComboBox x:Name="MicrophoneList" Width="420" Height="40" HorizontalAlignment="Left" Margin="0,0,0,20"
                      hc:InfoElement.Placeholder="{DynamicResource SelectMicrophone}"
                      SelectionChanged="MicrophoneList_SelectionChanged"/>

            <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,20"
                    MaxWidth="620" HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource MicrophoneSensitivity}" FontSize="15" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Slider x:Name="MicrophoneSensitivitySlider" Grid.Column="1" Minimum="0" Maximum="100"
                            TickFrequency="1" IsMoveToPointEnabled="True" VerticalAlignment="Center"
                            ValueChanged="MicrophoneSensitivitySlider_ValueChanged"/>
                    <TextBlock x:Name="SensitivityPercentText" Grid.Column="2" Text="0%" FontSize="15"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                <Button x:Name="StartButton" Content="{DynamicResource StartRecording}" Width="200" Height="50" Click="StartMic_Click" Margin="0,0,20,0" Style="{StaticResource ButtonPrimary}"/>
                <Button Content="{DynamicResource StopRecording}" Width="200" Height="50" Click="StopMic_Click" Margin="0,0,20,0" Style="{StaticResource ButtonDefault}"/>
                <Button x:Name="PlaybackButton" Content="{DynamicResource Playback}" Width="160" Height="50" Click="Playback_Click" IsEnabled="False" Style="{StaticResource ButtonDefault}"/>
            </StackPanel>
            <TextBlock x:Name="StatusText" Text="{DynamicResource NoRecording}" FontSize="16" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBlock Text="{DynamicResource VolumeLevel}" FontSize="16" Margin="0,0,0,10" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <ProgressBar x:Name="VolumeMeter" Minimum="0" Maximum="1" Height="30"/>
        </StackPanel>
    </Grid>
</UserControl>
