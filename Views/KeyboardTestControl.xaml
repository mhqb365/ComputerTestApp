<UserControl x:Class="ComputerTestApp.Views.KeyboardTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="UserControl_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource KeyboardTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource KeyboardInstruction}" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>
        
        <Border Grid.Row="1" Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,20"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                    <StackPanel x:Name="HistoryPanel" Orientation="Horizontal"/>
                </ScrollViewer>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="10,2">
                        <TextBlock x:Name="TotalKeysText" Text="0" Foreground="{DynamicResource ReverseTextBrush}" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <TextBlock Text="{DynamicResource KeysLabel}" Margin="5,0,0,0" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource Reset}" Click="ResetButton_Click" Margin="20,0,0,0" Style="{StaticResource ButtonDefault}" Height="30" Padding="10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource RegionBrush}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <Viewbox Stretch="Uniform">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,15,0">
                        <StackPanel x:Name="MainBlock" Orientation="Vertical"/>
                        <!-- Mouse Buttons Row -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                            <Border x:Name="MouseLeftBtn" CornerRadius="8" Margin="4,0" Padding="0" Width="180" Height="48"
                                    BorderThickness="1" Cursor="Hand">
                                <TextBlock Text="{DynamicResource MouseLeft}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Medium"/>
                            </Border>
                            <Border x:Name="MouseMiddleBtn" CornerRadius="8" Margin="4,0" Padding="0" Width="120" Height="48"
                                    BorderThickness="1" Cursor="Hand">
                                <TextBlock Text="{DynamicResource MouseMiddle}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Medium"/>
                            </Border>
                            <Border x:Name="MouseRightBtn" CornerRadius="8" Margin="4,0" Padding="0" Width="180" Height="48"
                                    BorderThickness="1" Cursor="Hand">
                                <TextBlock Text="{DynamicResource MouseRight}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="Medium"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                    <Grid x:Name="NavBlock" Margin="0,0,15,0" VerticalAlignment="Top"/>
                    <Grid x:Name="NumpadBlock"/>
                </StackPanel>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>
