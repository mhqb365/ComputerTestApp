<UserControl x:Class="ComputerTestApp.Views.SoundTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource SpeakerTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource SpeakerDescription}" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>

            <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,0"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="140"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource SystemVolume}" FontSize="15" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Slider x:Name="SystemVolumeSlider" Grid.Column="1" Minimum="0" Maximum="100"
                            TickFrequency="1" IsMoveToPointEnabled="True" VerticalAlignment="Center"
                            ValueChanged="SystemVolumeSlider_ValueChanged"/>
                    <TextBlock x:Name="VolumePercentText" Grid.Column="2" Text="0%" FontSize="15"
                               Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Text="{DynamicResource SpeakerOutputStatus}" FontSize="15"
                               VerticalAlignment="Center" Margin="0,16,20,0"/>
                    <TextBlock x:Name="SpeakerMuteStatusText" Grid.Row="1" Grid.Column="1" FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"
                               Margin="0,16,0,0"/>
                    <Button x:Name="SpeakerMuteButton" Grid.Row="1" Grid.Column="3" Height="34"
                            Margin="20,16,0,0" Click="SpeakerMuteButton_Click"
                            Style="{StaticResource ButtonDefault}"/>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,30,0,0">
                <Button x:Name="LeftButton" Content="{DynamicResource PlayLeft}" Width="200" Height="50" Margin="0,0,20,0" Click="PlayLeft_Click" Style="{StaticResource ButtonPrimary}"/>
                <Button x:Name="RightButton" Content="{DynamicResource PlayRight}" Width="200" Height="50" Click="PlayRight_Click" Style="{StaticResource ButtonDefault}"/>
            </StackPanel>
            <Button x:Name="SampleAudioButton" Content="{DynamicResource PlaySampleAudio}" Width="200" Height="50"
                    HorizontalAlignment="Left" Margin="0,20,0,0" Click="SampleAudioButton_Click"
                    Style="{StaticResource ButtonDefault}"/>
            <TextBlock x:Name="StatusText" Text="{DynamicResource SpeakerReady}" Margin="0,20,0,0" FontSize="16" HorizontalAlignment="Left" Foreground="{DynamicResource SecondaryTextBrush}"/>
        </StackPanel>
    </Grid>
</UserControl>
