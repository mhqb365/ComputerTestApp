<UserControl x:Class="ComputerTestApp.Views.MouseTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             Loaded="UserControl_Loaded">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="CHUỘT (MOUSE TEST)" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Di chuyển và click chuột trong vùng viền dưới đây để kiểm tra." Margin="0,0,0,20"/>
            
            <Border x:Name="MouseArea" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="8" Height="400" Background="Transparent"
                    MouseDown="MouseArea_MouseDown" MouseUp="MouseArea_MouseUp" MouseWheel="MouseArea_MouseWheel" MouseMove="MouseArea_MouseMove">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="ClickDisplay" Text="Chưa click" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock x:Name="WheelDisplay" Text="Chưa cuộn" FontSize="24" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryHueMidBrush}" Margin="0,0,0,10"/>
                    <TextBlock x:Name="PositionDisplay" Text="X: 0 | Y: 0" FontSize="20" HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
