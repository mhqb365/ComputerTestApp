<UserControl x:Class="ComputerTestApp.Views.ScreenTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="{DynamicResource ScreenTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource ScreenDescription}" Margin="0,0,0,20"/>
            <TextBlock Text="{DynamicResource ScreenInstruction}" Margin="0,0,0,20" FontStyle="Italic"/>
            <Button Content="{DynamicResource StartTest}" Width="200" Height="50" FontSize="16" Click="StartTest_Click" HorizontalAlignment="Left" Style="{StaticResource ButtonPrimary}"/>
        </StackPanel>
    </Grid>
</UserControl>
