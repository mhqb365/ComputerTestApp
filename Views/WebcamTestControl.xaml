<UserControl x:Class="ComputerTestApp.Views.WebcamTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource WebcamTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource WebcamDescription}" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="CameraList" Width="300" Height="40" hc:InfoElement.Placeholder="{DynamicResource SelectCamera}" Margin="0,0,20,0"/>
                <Button x:Name="CameraToggleButton" Content="{DynamicResource Start}" Width="120" Height="40"
                        Click="CameraToggleButton_Click" Style="{StaticResource ButtonPrimary}"/>
            </StackPanel>
            <Border Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,20,0,0"
                    MaxWidth="440" HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{DynamicResource CameraStatus}" FontSize="15" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock x:Name="CameraStatusText" Grid.Column="1" FontSize="15"
                               Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <Border x:Name="CameraPreview" Grid.Row="2" Visibility="Collapsed"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Background="{DynamicResource SecondaryRegionBrush}">
            <Image x:Name="CameraImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</UserControl>
