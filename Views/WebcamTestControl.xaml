<UserControl x:Class="ComputerTestApp.Views.WebcamTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource WebcamTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource WebcamDescription}" Margin="0,0,0,20" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <ComboBox x:Name="CameraList" Width="300" Height="40" hc:InfoElement.Placeholder="{DynamicResource SelectCamera}" Margin="0,0,20,0"/>
            <Button Content="{DynamicResource Start}" Width="120" Height="40" Click="StartCamera_Click" Margin="0,0,10,0" Style="{StaticResource ButtonPrimary}"/>
            <Button Content="{DynamicResource Stop}" Width="120" Height="40" Click="StopCamera_Click" Style="{StaticResource ButtonDefault}"/>
        </StackPanel>

        <Border x:Name="CameraPreview" Grid.Row="2" Visibility="Collapsed"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Background="{DynamicResource SecondaryRegionBrush}">
            <Image x:Name="CameraImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</UserControl>
