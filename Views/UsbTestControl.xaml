<UserControl x:Class="ComputerTestApp.Views.UsbTestControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{DynamicResource UsbTitle}" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock Text="{DynamicResource UsbDescription}"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,20"/>
        </StackPanel>

        <Border x:Name="DeviceCard" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Top"
                Background="{DynamicResource RegionBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="24" MaxWidth="720" HorizontalAlignment="Left">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{DynamicResource UsbDetected}"
                           FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"
                           Margin="0,0,0,20"/>

                <TextBlock Grid.Row="1" Text="{DynamicResource Device}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,12"/>
                <TextBlock x:Name="DeviceNameText" Grid.Row="1" Grid.Column="1" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="2" Text="{DynamicResource Manufacturer}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,12"/>
                <TextBlock x:Name="ManufacturerText" Grid.Row="2" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="3" Text="{DynamicResource Status}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,12"/>
                <TextBlock x:Name="StatusText" Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"/>

                <TextBlock Grid.Row="4" Text="{DynamicResource DeviceId}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,12,0"/>
                <TextBlock x:Name="DeviceIdText" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
